package timestamp;

import github.com/oghamlang/std/validate;

// Timestamp — compatible with google.protobuf.Timestamp.
// Seconds since 1970-01-01T00:00:00Z + sub-second nanos.
type Timestamp {
    // Seconds since epoch. Can be negative for pre-epoch.
    int64 seconds = 1;
    // Non-negative fractions of a second at nanosecond resolution.
    @validate::Range(min=0, max=999999999)
    int32 nanos = 2;
}
