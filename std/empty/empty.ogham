package empty;

// Empty — a message with no fields.
// Compatible with google.protobuf.Empty.
//
// In most cases you should use the `void` keyword instead:
//
//   rpc Ping(void) -> void;
//
// Use Empty only when you need an empty message as a field type:
//
//   type Event {
//       string name = 1;
//       empty.Empty metadata = 2;   // placeholder for future fields
//   }
type Empty {
}
